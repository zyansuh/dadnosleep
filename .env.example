# ──────────────────────────────────────────────────────
#  아빠안잔다 환경변수 설정 파일
#  이 파일을 복사해 .env.local 로 저장한 뒤 값을 입력하세요.
#  .env.local 은 .gitignore 에 포함되어 Git에 업로드되지 않습니다.
# ──────────────────────────────────────────────────────

# TMDB API 키 (https://www.themoviedb.org/settings/api)
VITE_TMDB_API_KEY=

# TMDB 읽기 액세스 토큰 (Bearer 인증 — API 키보다 권장)
VITE_TMDB_READ_TOKEN=

# YouTube Data API v3 키 (https://console.cloud.google.com)
VITE_YOUTUBE_API_KEY=

# 커뮤니티·편성표·건의함 공유 저장소 (JSONBin — PC·모바일 동일 데이터)
# https://jsonbin.io 에서 Bin 생성 후 ID·Access Key 입력
VITE_JSONBIN_BIN_ID=
VITE_JSONBIN_ACCESS_KEY=

# 동호회 회원 화이트리스트 (선택 — 비우면 VITE_JSONBIN_BIN_ID Bin 안에 members 필드로 저장)
VITE_JSONBIN_BIN_MEMBERS=

# 회원 계정 저장용 JSONBin (별도 Bin 권장 — 서버 전용)
JSONBIN_USERS_BIN_ID=
JSONBIN_ACCESS_KEY=

# JWT 서명 비밀키 (프로덕션 필수 — 32자 이상 랜덤 문자열)
# Discord 관리자 로그인 시 발급되는 adminToken 서명에 사용
JWT_SECRET=

# Discord 관리자 @username 목록 (쉼표 구분, 선택)
# 비우면 src/constants/adminUsers.ts 의 DEFAULT 목록 사용
VITE_ADMIN_DISCORD_USERS=
ADMIN_DISCORD_USERS=

# 관리자 이메일 (쉼표 구분, 가입 시 admin 역할 부여 — 이메일 auth 사용 시)
ADMIN_EMAILS=admin@example.com

# Discord OAuth — 프론트 (로그인 버튼·리다이렉트 URI)
VITE_DISCORD_CLIENT_ID=
VITE_DISCORD_REDIRECT_URI=http://localhost:5173/auth/callback

# Discord OAuth — 서버 전용 (Vercel·로컬 dev API — client_secret 은 VITE_ 접두사 금지)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:5173/auth/callback
# Vercel 에는 위 DISCORD_* 세 개를 반드시 등록 (VITE_DISCORD_CLIENT_SECRET 만으로는 부족할 수 있음)
